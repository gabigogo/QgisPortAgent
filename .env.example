# ── GitHub MCP Server ──────────────────────────────────────────────────────
# Personal Access Token (fine-grained recommended).
# Required for: GitHub MCP Server (repo / issue / PR / Actions tools).
# Create at: https://github.com/settings/personal-access-tokens/new
# Minimum permissions: Contents (read), Issues (read/write), Pull Requests
# (read/write), Actions (read), Metadata (read).
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxx

# ── QGIS MCP Socket ──────────────────────────────────────────────────────
# Port the QGIS MCP plugin listens on (default: 9876).
# Change only if port 9876 is already in use on your machine.
# QGIS_MCP_PORT=9876

# Optional: require auth token in the QGIS MCP plugin (default: disabled).
# Set to 1/true/yes/on to require authentication.
# QGIS_MCP_REQUIRE_AUTH=0

# Optional auth token used by qgis_mcp_server.py when auth is enabled.
# If auth is disabled in QGIS MCP, this value is ignored.
# QGIS_MCP_TOKEN=
